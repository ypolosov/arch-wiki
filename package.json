{
  "name": "arch-wiki",
  "version": "0.20.0",
  "private": true,
  "description": "Deterministic core (CLI) for the arch-wiki Claude Code plugin.",
  "license": "MIT",
  "author": "ypolosov",
  "engines": {
    "node": ">=18"
  },
  "bin": {
    "arch-wiki": "bin/arch-wiki"
  },
  "scripts": {
    "build": "node esbuild.config.cjs",
    "typecheck": "tsc --noEmit",
    "test:unit": "jest --selectProjects unit",
    "test:int": "jest --selectProjects integration",
    "test:e2e": "npm run build && jest --selectProjects e2e",
    "test:bats": "bats scripts/*.bats",
    "test": "npm run typecheck && jest --selectProjects unit integration && npm run test:e2e"
  },
  "dependencies": {
    "cac": "^6.7.14",
    "gray-matter": "^4.0.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "esbuild": "^0.23.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.5.4"
  }
}
